use kvs::KvStore;
use kvs::Result;
use std::env;
use std::io;
use std::process;

fn main() -> Result<()> {
    let mut kvs = KvStore::open(&env::current_dir()?)?;

    loop {
        let mut buffer = String::new();
        println!("Please input command log:");
        io::stdin().read_line(&mut buffer)?;
        let mut iter = buffer.split_whitespace();
        let command = iter.next().unwrap_or("");
        let key = iter.next().unwrap_or("");
        let value = iter.next().unwrap_or("");
        println!("{command},{key},{value}");
        match command {
            "-V" => println!("{}", env!("CARGO_PKG_VERSION")),
            "set" => {
                if value.is_empty() {
                    process::exit(1);
                } else {
                    kvs.set(key.to_string(), value.to_string())?;
                }
            }
            "get" => {
                if !value.is_empty() {
                    process::exit(1);
                    //return Err(kvs::error::KvError::Other);
                } else {
                    let Ok(Some(_)) = kvs.get(key.to_string()) else {
                        process::exit(0);
                    };
                }
            }
            "rm" => {
                if key.is_empty() || !value.is_empty() {
                    process::exit(1);
                } else {
                    let Ok(_) = kvs.remove(key.to_string()) else {
                        process::exit(1);
                    };
                }
            }
            "compact" => {
                let mut i = 1024 * 1024u64;
                while i < 1_125_899_906_842_625 {
                    for e in 1..10000 {
                        kvs.set(e.to_string(), i.to_string())?;
                    }
                    i *= 1024;
                }
            }
            _ => break Ok(()),
        }
    }
}
